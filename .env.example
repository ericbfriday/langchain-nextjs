# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL="file:./prisma/dev.db"

# ==========================================
# Authentication Secret
# ==========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-character-minimum-secret-key-here"

# ==========================================
# Okta SSO Configuration
# ==========================================
OKTA_ISSUER="https://dev-xxxxx.okta.com"
OKTA_CLIENT_ID="your-okta-client-id"
OKTA_CLIENT_SECRET="your-okta-client-secret"

# ==========================================
# Application Configuration
# ==========================================
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Security Configuration
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Cookie domain for cross-subdomain auth
COOKIE_DOMAIN=".yourdomain.com"

# Rate limiting
MAX_LOGIN_ATTEMPTS="5"
RATE_LIMIT_WINDOW="900" # 15 minutes in seconds

# Session configuration
SESSION_EXPIRE_DAYS="7"
SESSION_IDLE_TIMEOUT="1800" # 30 minutes in seconds

# ==========================================
# Workspace Configuration
# ==========================================
DEFAULT_DOMAIN="yourdomain.com"
ADMIN_EMAIL="admin@yourdomain.com"

# ==========================================
# Monitoring & Logging
# ==========================================
AUDIT_LOG_RETENTION_DAYS="90"
LOG_LEVEL="info" # debug, info, warn, error

# ==========================================
# Optional: Email Configuration (for notifications)
# ==========================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# EMAIL_FROM="noreply@yourdomain.com"

# ==========================================
# Optional: Monitoring Services
# ==========================================
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx"

# ==========================================
# Optional: OpenAI (for LangChain features)
# ==========================================
# OPENAI_API_KEY="sk-..."

# ==========================================
# Optional: Supabase (if using Supabase features)
# ==========================================
# NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="xxx"
